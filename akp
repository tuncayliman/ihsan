<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Keçiören Ak Parti İlçe Teşkilatı - Sorun Takip Sistemi</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React & Babel CDN -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .loading-spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #f97316;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="bg-slate-50">
    <div id="root">
        <div class="flex items-center justify-center h-screen">
            <div class="text-center">
                <div class="loading-spinner mx-auto mb-4"></div>
                <p class="text-slate-500 font-medium">Sistem Yükleniyor...</p>
            </div>
        </div>
    </div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const LOGO_URL = "https://upload.wikimedia.org/wikipedia/tr/d/d5/Adalet_ve_Kalk%C4%B1nma_Partisi_logo.png";

        // Roller ve Durumlar
        const ROLES = {
            MAHALLE_BASKANI: 'Mahalle Başkanı',
            GRUP_LIDERI: 'Grup Lideri',
            TESKILAT_BASKANI: 'Teşkilat Başkanı',
            ILCE_BASKANI: 'İlçe Başkanı'
        };

        const STATUS = {
            GRUP_LIDERINDE: 'Grup liderine gönderildi',
            TESKILAT_BASKANINDA: 'Teşkilat başkanına iletildi',
            ILCE_BASKANINDA: 'İlçe başkanına iletildi',
            COZULDU: 'Sorun çözüldü'
        };

        // --- SVG İkon Bileşenleri ---
        const Icon = ({ name, size = 20, className = "", fill = "none" }) => {
            const icons = {
                lightbulb: (
                    <React.Fragment>
                        <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A5 5 0 0 0 8 8c0 1.3.5 2.6 1.5 3.5.8.8 1.3 1.5 1.5 2.5" />
                        <path d="M9 18h6" />
                        <path d="M10 22h4" />
                    </React.Fragment>
                ),
                plus: <path d="M12 5v14M5 12h14" />,
                check: <path d="M20 6 9 17l-5-5" />,
                alert: (
                    <React.Fragment>
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" x2="12" y1="8" y2="12" />
                        <line x1="12" x2="12.01" y1="16" y2="16" />
                    </React.Fragment>
                ),
                arrowUp: (
                    <React.Fragment>
                        <path d="m16 12-4-4-4 4" />
                        <path d="M12 16V8" />
                    </React.Fragment>
                ),
                user: (
                    <React.Fragment>
                        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </React.Fragment>
                ),
                logout: (
                    <React.Fragment>
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <path d="M16 17l5-5-5-5" />
                        <path d="M21 12H9" />
                    </React.Fragment>
                ),
                list: (
                    <React.Fragment>
                        <line x1="8" x2="21" y1="6" y2="6" />
                        <line x1="8" x2="21" y1="12" y2="12" />
                        <line x1="8" x2="21" y1="18" y2="18" />
                        <line x1="3" x2="3.01" y1="6" y2="6" />
                        <line x1="3" x2="3.01" y1="12" y2="12" />
                        <line x1="3" x2="3.01" y1="18" y2="18" />
                    </React.Fragment>
                ),
                pin: (
                    <React.Fragment>
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                        <circle cx="12" cy="10" r="3" />
                    </React.Fragment>
                ),
                clock: (
                    <React.Fragment>
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </React.Fragment>
                ),
                calendar: (
                    <React.Fragment>
                        <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                        <line x1="16" x2="16" y1="2" y2="6" />
                        <line x1="8" x2="8" y1="2" y2="6" />
                        <line x1="3" x2="21" y1="10" y2="10" />
                    </React.Fragment>
                ),
                image: (
                    <React.Fragment>
                        <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                        <circle cx="9" cy="9" r="2" />
                        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                    </React.Fragment>
                ),
                chevronRight: <path d="m9 18 6-6-6-6" />,
                shield: <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
            };
            return (
                <svg width={size} height={size} viewBox="0 0 24 24" fill={fill} stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
                    {icons[name]}
                </svg>
            );
        };

        // --- Ana Uygulama ---
        const App = () => {
            const [userProfile, setUserProfile] = useState(null);
            const [loading, setLoading] = useState(false);
            const [reports, setReports] = useState([]);
            const [showAddModal, setShowAddModal] = useState(false);
            const [view, setView] = useState('login');

            // Yerel depolamadan verileri yükle
            useEffect(() => {
                const savedReports = localStorage.getItem('kecioren_reports');
                if (savedReports) {
                    setReports(JSON.parse(savedReports));
                }
            }, []);

            // Veriler değiştikçe yerel depolamaya kaydet
            useEffect(() => {
                localStorage.setItem('kecioren_reports', JSON.stringify(reports));
            }, [reports]);

            const handleLogin = (role, name, id, parentId = null) => {
                setUserProfile({ role, name, id, parentId });
                setView('dashboard');
            };

            const addReport = (formData) => {
                const newReport = {
                    id: Date.now().toString(),
                    ...formData,
                    reporterUid: userProfile.id,
                    reporterName: userProfile.name,
                    groupLeaderId: userProfile.parentId,
                    level: 0,
                    status: STATUS.GRUP_LIDERINDE,
                    createdAt: new Date().toISOString()
                };
                setReports([newReport, ...reports]);
                setShowAddModal(false);
            };

            const updateStatus = (reportId, nextLevel, nextStatus) => {
                const updatedReports = reports.map(r => {
                    if (r.id === reportId) {
                        return { ...r, level: nextLevel, status: nextStatus, updatedAt: new Date().toISOString() };
                    }
                    return r;
                });
                setReports(updatedReports);
            };

            // Filtreleme Mantığı
            const filteredReports = reports.filter(r => {
                if (!userProfile) return false;
                if (userProfile.role === ROLES.MAHALLE_BASKANI) {
                    return r.reporterUid === userProfile.id;
                } else if (userProfile.role === ROLES.GRUP_LIDERI) {
                    // Kendi bildirdiği veya kendisine bağlı olanları görür
                    return r.groupLeaderId === userProfile.id || r.reporterUid === userProfile.id;
                } else if (userProfile.role === ROLES.TESKILAT_BASKANI) {
                    return r.level >= 1;
                } else if (userProfile.role === ROLES.ILCE_BASKANI) {
                    return r.level >= 2;
                }
                return false;
            });

            if (view === 'login') return <LoginScreen onLogin={handleLogin} />;

            return (
                <div className="max-w-4xl mx-auto pb-20">
                    <header className="bg-white border-b sticky top-0 z-10 px-4 py-3 flex items-center justify-between shadow-sm">
                        <div className="flex items-center gap-3">
                            <img src={LOGO_URL} alt="Logo" className="h-10 w-auto object-contain" />
                            <div>
                                <h1 className="font-bold text-sm sm:text-lg leading-tight text-slate-800">Keçiören Ak Parti İlçe Teşkilatı</h1>
                                <p className="text-[10px] text-orange-600 font-bold uppercase tracking-tighter">Sorun Takip Sistemi</p>
                            </div>
                        </div>
                        <div className="flex items-center gap-3">
                            <div className="text-right hidden sm:block">
                                <p className="text-sm font-bold text-slate-800">{userProfile.name}</p>
                                <p className="text-[10px] text-orange-600 font-black uppercase">{userProfile.role}</p>
                            </div>
                            <button onClick={() => setView('login')} className="p-2 hover:bg-orange-50 rounded-full text-slate-400 hover:text-orange-600 transition-colors">
                                <Icon name="logout" size={20} />
                            </button>
                        </div>
                    </header>

                    <div className="p-4 mt-2">
                        <div className="bg-gradient-to-br from-orange-500 via-orange-600 to-blue-900 rounded-2xl p-6 text-white shadow-xl text-center sm:text-left">
                            <h2 className="text-xl sm:text-2xl font-black mb-1 italic tracking-widest uppercase text-orange-100">TÜRKİYE YÜZYILI</h2>
                            <h2 className="text-lg sm:text-xl font-bold mb-1 opacity-90 tracking-tight">Hoş Geldiniz, {userProfile.name}</h2>
                            <p className="text-orange-50 text-xs sm:text-sm opacity-80 font-medium">Hizmet yolunda mahallemizin her derdi bizim derdimizdir.</p>
                        </div>
                    </div>

                    {userProfile.role === ROLES.MAHALLE_BASKANI && (
                        <div className="px-4 py-2">
                            <button onClick={() => setShowAddModal(true)} className="w-full bg-white border-2 border-dashed border-orange-300 rounded-xl p-4 flex items-center justify-center gap-2 text-orange-600 font-bold hover:bg-orange-50 transition-all shadow-sm">
                                <Icon name="plus" size={20} /> Yeni Sorun Kaydı Oluştur
                            </button>
                        </div>
                    )}

                    <div className="p-4 space-y-4">
                        <h3 className="font-black text-slate-700 flex items-center gap-2 uppercase text-xs tracking-widest border-l-4 border-orange-600 pl-2">
                            GÜNCEL DURUM ({filteredReports.length})
                        </h3>
                        {filteredReports.length === 0 ? (
                            <div className="text-center py-16 bg-white rounded-3xl border border-slate-200">
                                <img src={LOGO_URL} className="h-16 mx-auto grayscale opacity-20 mb-4" />
                                <p className="text-slate-500 italic font-medium">Henüz kayıtlı sorun bulunmamaktadır.</p>
                            </div>
                        ) : filteredReports.map(r => <ReportCard key={r.id} report={r} userProfile={userProfile} onUpdate={updateStatus} />)}
                    </div>

                    {showAddModal && (
                        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
                            <div className="bg-white w-full max-w-lg rounded-t-3xl sm:rounded-2xl p-6 shadow-2xl overflow-y-auto max-h-[90vh]">
                                <div className="flex justify-between items-center mb-6">
                                    <h2 className="text-xl font-black text-slate-800 uppercase">Yeni Sorun Bildirimi</h2>
                                    <button onClick={() => setShowAddModal(false)} className="text-slate-400"><Icon name="plus" className="rotate-45" size={28} /></button>
                                </div>
                                <ReportForm onSubmit={addReport} />
                            </div>
                        </div>
                    )}
                </div>
            );
        };

        const LoginScreen = ({ onLogin }) => (
            <div className="flex flex-col items-center justify-center min-h-screen p-6 bg-slate-50 relative overflow-hidden">
                <div className="absolute top-[-10%] right-[-10%] w-64 h-64 bg-orange-100 rounded-full blur-3xl opacity-50"></div>
                <div className="absolute bottom-[-10%] left-[-10%] w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-50"></div>
                <div className="w-full max-w-md bg-white rounded-3xl p-8 shadow-2xl border border-slate-100 relative z-10">
                    <div className="flex flex-col items-center mb-8">
                        <img src={LOGO_URL} alt="AK Parti" className="h-24 w-auto mb-4 drop-shadow-xl" />
                        <h1 className="text-xl sm:text-2xl font-black text-slate-800 text-center uppercase tracking-tighter leading-none mb-2">Keçiören Ak Parti</h1>
                        <p className="text-orange-600 font-bold uppercase tracking-widest text-[10px] underline decoration-2 underline-offset-4 text-center">SORUN TAKİP SİSTEMİ</p>
                    </div>
                    <div className="space-y-3">
                        <LoginButton onClick={() => onLogin(ROLES.MAHALLE_BASKANI, "İhsan TAŞ", "B1", "L1")} name="İhsan TAŞ" role="Çiçekli Mah. Başkanı" icon="user" />
                        <LoginButton onClick={() => onLogin(ROLES.GRUP_LIDERI, "Özcan SAYGILI", "L1", "LB1")} name="Özcan SAYGILI" role="Grup Lideri" icon="shield" />
                        <LoginButton onClick={() => onLogin(ROLES.TESKILAT_BASKANI, "Ahmet ER", "LB1", "IB1")} name="Ahmet ER" role="Teşkilat Başkanı" icon="list" />
                        <LoginButton onClick={() => onLogin(ROLES.ILCE_BASKANI, "Ömer Faruk İSLAM", "IB1", null)} name="Ömer Faruk İSLAM" role="İlçe Başkanı" icon="shield" isBlue />
                    </div>
                    <p className="mt-8 text-center text-[10px] text-slate-400 font-black uppercase tracking-widest">Durmak Yok Yola Devam</p>
                </div>
            </div>
        );

        const LoginButton = ({ onClick, name, role, icon, isBlue }) => (
            <button onClick={onClick} className={`w-full flex items-center justify-between p-4 rounded-2xl border transition-all group ${isBlue ? 'bg-blue-900 text-white border-blue-900' : 'bg-slate-50 border-slate-200 hover:bg-orange-500 hover:text-white hover:border-orange-500'}`}>
                <div className="flex items-center gap-3">
                    <div className={`p-2 rounded-lg ${isBlue ? 'bg-white/10 text-white' : 'bg-white shadow-sm group-hover:text-orange-600 text-slate-500'}`}><Icon name={icon} /></div>
                    <div className="text-left">
                        <p className="font-black text-sm">{name}</p>
                        <p className={`text-[10px] font-bold uppercase opacity-70 ${isBlue ? '' : 'text-slate-500 group-hover:text-white'}`}>{role}</p>
                    </div>
                </div>
                <Icon name="chevronRight" size={18} className="opacity-30 group-hover:opacity-100" />
            </button>
        );

        const ReportForm = ({ onSubmit }) => {
            const [data, setData] = useState({ subject: '', description: '', date: new Date().toISOString().split('T')[0], time: new Date().toTimeString().split(' ')[0].slice(0, 5), imageUrl: '', neighborhood: 'Çiçekli Mahallesi' });
            return (
                <form onSubmit={(e) => { e.preventDefault(); onSubmit(data); }} className="space-y-4">
                    <Input label="Sorun Başlığı" value={data.subject} onChange={v => setData({...data, subject: v})} placeholder="Örn: Yol Çalışması Talebi" required />
                    <div className="grid grid-cols-2 gap-4">
                        <Input label="Tarih" type="date" value={data.date} onChange={v => setData({...data, date: v})} icon="calendar" />
                        <Input label="Saat" type="time" value={data.time} onChange={v => setData({...data, time: v})} icon="clock" />
                    </div>
                    <div>
                        <label className="block text-[10px] font-black text-slate-500 uppercase mb-1">Detaylı Açıklama</label>
                        <textarea rows="4" className="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none font-medium text-sm" value={data.description} onChange={e => setData({...data, description: e.target.value})} required placeholder="Lütfen vatandaş talebini detaylandırınız..."></textarea>
                    </div>
                    <Input label="Görsel Linki" type="url" value={data.imageUrl} onChange={v => setData({...data, imageUrl: v})} icon="image" placeholder="https://..." />
                    <button type="submit" className="w-full bg-orange-600 text-white font-black py-4 rounded-xl shadow-lg shadow-orange-100 uppercase tracking-widest text-sm hover:bg-orange-700 transition-all">Kaydet ve Gönder</button>
                </form>
            );
        };

        const Input = ({ label, icon, onChange, ...props }) => (
            <div>
                <label className="block text-[10px] font-black text-slate-500 uppercase mb-1">{label}</label>
                <div className="relative">
                    {icon && <div className="absolute left-3 top-1/2 -translate-y-1/2 text-orange-500"><Icon name={icon} size={16} /></div>}
                    <input {...props} onChange={e => onChange(e.target.value)} className={`w-full p-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none font-medium text-sm ${icon ? 'pl-10' : ''}`} />
                </div>
            </div>
        );

        const ReportCard = ({ report, userProfile, onUpdate }) => {
            const colors = { 
                [STATUS.COZULDU]: 'bg-green-100 text-green-700 border-green-200', 
                [STATUS.ILCE_BASKANINDA]: 'bg-blue-900 text-white border-blue-900', 
                [STATUS.TESKILAT_BASKANINDA]: 'bg-orange-600 text-white border-orange-600' 
            };
            const badgeClass = colors[report.status] || 'bg-orange-100 text-orange-700 border-orange-200';
            
            const canEscalate = report.status !== STATUS.COZULDU && ((userProfile.role === ROLES.GRUP_LIDERI && report.level === 0) || (userProfile.role === ROLES.TESKILAT_BASKANI && report.level === 1));

            return (
                <div className="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all p-6">
                    <div className="flex justify-between items-start mb-4">
                        <div className="space-y-1">
                            <span className={`inline-block px-2 py-0.5 rounded-md text-[9px] font-black uppercase border tracking-tighter ${badgeClass}`}>{report.status}</span>
                            <h4 className="text-lg font-black text-slate-800 uppercase leading-none">{report.subject}</h4>
                        </div>
                        <div className="text-right text-[10px] font-bold text-slate-400 uppercase tracking-tighter">
                            <p className="flex items-center gap-1 justify-end"><Icon name="calendar" size={12} className="text-orange-500" /> {report.date}</p>
                            <p className="flex items-center gap-1 justify-end"><Icon name="clock" size={12} className="text-orange-500" /> {report.time}</p>
                        </div>
                    </div>
                    <p className="text-sm text-slate-600 mb-4 font-medium leading-relaxed">{report.description}</p>
                    {report.imageUrl && (
                        <div className="relative w-full h-48 mb-4 overflow-hidden rounded-2xl border border-slate-100">
                            <img src={report.imageUrl} className="w-full h-full object-cover" onError={e => e.target.parentElement.style.display='none'} />
                        </div>
                    )}
                    <div className="flex flex-wrap gap-4 pt-4 border-t border-slate-50 text-[10px] font-black uppercase text-slate-500">
                        <div className="flex items-center gap-1"><Icon name="pin" size={14} className="text-orange-600" /> {report.neighborhood}</div>
                        <div className="flex items-center gap-1"><Icon name="user" size={14} className="text-blue-900" /> Bildiren: {report.reporterName}</div>
                    </div>
                    {userProfile.role !== ROLES.MAHALLE_BASKANI && report.status !== STATUS.COZULDU && (
                        <div className="flex gap-2 mt-4 pt-4 border-t border-slate-50">
                            <button onClick={() => onUpdate(report.id, report.level, STATUS.COZULDU)} className="flex-1 bg-green-600 text-white py-3 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-green-700 shadow-md shadow-green-100">Çözüldü</button>
                            {canEscalate && <button onClick={() => onUpdate(report.id, report.level + 1, report.level === 0 ? STATUS.TESKILAT_BASKANINDA : STATUS.ILCE_BASKANINDA)} className="flex-1 bg-orange-50 text-orange-700 border border-orange-200 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-orange-100 italic">Üst Makama İlet</button>}
                        </div>
                    )}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
